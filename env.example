# Ollama配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# 语音处理配置（使用本地Whisper和gTTS/pyttsx3，不通过Ollama）
STT_MODEL=base
TTS_ENGINE=gtts

# 数据库配置
# Redis配置（使用Docker Compose启动的Redis）
# 格式: redis://:密码@主机:端口/数据库编号
REDIS_URL=redis://:m-bot-redis-password@localhost:6379/0
REDIS_PASSWORD=m-bot-redis-password

# SQLite数据库配置
# 格式: sqlite:///相对路径 或 sqlite:///绝对路径
# 示例: sqlite:///./data/m_bot.db (相对路径，存储在项目根目录的data文件夹)
# 示例: sqlite:///C:/path/to/db.db (绝对路径，Windows)
# 示例: sqlite:////path/to/db.db (绝对路径，Linux/Mac)
# 如果不设置，默认使用: data/m_bot.db
DATABASE_URL=sqlite:///./data/m_bot.db

# ChromaDB配置（使用Docker Compose启动的ChromaDB，可选）
# 注意：当前项目未实际使用ChromaDB，这些配置仅用于Docker Compose
# CHROMA_HOST=localhost
# CHROMA_PORT=8000

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log

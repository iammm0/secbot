# =============================================================================
# Secbot 开发环境变量模板
# -----------------------------------------------------------------------------
# 使用方式：复制到仓库根目录并重命名为 .env（不要提交含真实密钥的 .env）
#   cp .env.backup .env
#
# 说明：
# - dotenv 默认从「当前工作目录」加载 .env；请在仓库根目录运行 CLI（secbot / uv run secbot
#   或 python scripts/main.py），以便 DATABASE_URL、LOG_FILE 等相对路径与 data/、logs/ 一致。
# - 若在 SQLite 里通过 /model 等保存过配置，部分项会优先于本文件的值（见 hackbot_config）。
# =============================================================================

# ----------------------------------------------------------------------------- 
# 推理后端（必填其一策略）
# -----------------------------------------------------------------------------
# 厂商 ID 与 utils/model_selector.PROVIDER_REGISTRY 一致，例如：
#   ollama | deepseek | openai | anthropic | google | groq | custom | ...
LLM_PROVIDER=deepseek

# 当前模型是否支持工具 / function calling（不支持的工具型智能体会降级）
# 常见：部分本地小模型填 false
LLM_TOOLS_SUPPORTED=true

# ----------------------------------------------------------------------------- 
# Ollama（当 LLM_PROVIDER=ollama）
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TEMPERATURE=0.7

# ----------------------------------------------------------------------------- 
# DeepSeek（当 LLM_PROVIDER=deepseek）
# -----------------------------------------------------------------------------
# 获取 API Key: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-************************
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 聊天: deepseek-chat | 推理: deepseek-reasoner（也可用 secbot model 切换）
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
DEEPSEEK_TEMPERATURE=0.7

# ----------------------------------------------------------------------------- 
# 其他云端厂商（按需取消注释；密钥名一般为 <厂商大写>_API_KEY）
# -----------------------------------------------------------------------------
# OpenAI 兼容（OpenAI / 中转 / Groq 等多用 OPENAI_API_KEY + OPENAI_BASE_URL）
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-************************
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Anthropic（原生，非 OpenAI 兼容变量名以厂商为准，可用 secbot model 写入 SQLite）
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-************************

# Google Gemini
# LLM_PROVIDER=google
# GOOGLE_API_KEY=************************

# 更多厂商见 docs/LLM_PROVIDERS.md

# ----------------------------------------------------------------------------- 
# 可选：FastAPI 服务（secbot server）
# -----------------------------------------------------------------------------
SECBOT_SERVER_HOST=0.0.0.0
SECBOT_SERVER_PORT=8000
# 开发热重载：true / false（生产环境建议 false）
SECBOT_SERVER_RELOAD=false

# ----------------------------------------------------------------------------- 
# 数据与缓存
# -----------------------------------------------------------------------------
# SQLite：相对路径相对于进程 cwd，开发请在仓库根目录运行
DATABASE_URL=sqlite:///./data/secbot.db
# 可选 Redis（未使用可留空）
# REDIS_URL=redis://localhost:6379/0

# ----------------------------------------------------------------------------- 
# 日志
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
# 是否在启动时打印详细初始化日志
VERBOSE_INIT=false

# 单条日志截断（避免过长）
LOG_MAX_MESSAGE_CHARS=2000
LOG_MAX_FIELD_CHARS=1000
LOG_MAX_LIST_ITEMS=20
# 逗号分隔的敏感字段名，日志会弱化输出
LOG_SENSITIVE_KEYS=password,passwd,token,api_key,authorization,cookie,set-cookie,secret,stdin_data,auth_value

# ReAct 思考过程日志采样（每 N 条、最短字符）
THOUGHT_CHUNK_LOG_EVERY_N=10
THOUGHT_CHUNK_MIN_CHARS=80

# ----------------------------------------------------------------------------- 
# 语音（可选）
# -----------------------------------------------------------------------------
STT_ENGINE=fast_whisper
STT_MODEL=base
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_VAD_FILTER=true

TTS_ENGINE=gtts

# ----------------------------------------------------------------------------- 
# OSINT / 外部情报 API（可选，也可用密钥环存储）
# -----------------------------------------------------------------------------
# SHODAN_API_KEY=
# VIRUSTOTAL_API_KEY=

# ----------------------------------------------------------------------------- 
# 其它
# -----------------------------------------------------------------------------
# 禁用 Python 写 pyc（可选，scripts/main.py 已默认设置）
# PYTHONDONTWRITEBYTECODE=1

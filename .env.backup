# =============================================================================
# Secbot 环境变量参考（可选 · 非发布后的必经步骤）
# -----------------------------------------------------------------------------
# 复制为 .env 仅在你需要：无界面运行、CI/CD、容器固定默认值、或显式覆盖某次进程环境。
#
# 配置真源（发布后用户侧「应持久化」的常量）
# -----------------------------------------------------------------------------
# 模型厂商、API Key、默认模型、Base URL、日志级别等，推荐在进入程序后配置，并写入本地
# SQLite（与 DATABASE_URL 对应库中的 user_configs 等表）。持久化后再次启动会优先使用库内
# 值，而不是本文件（详见 hackbot_config：多数项为「SQLite > 环境变量 > 内置默认」）。
#
# 首次使用可跳过本文件：启动 `secbot`（或交互模式）后通过 `/model`、或命令行 `secbot model`
# 等完成配置即可；无需事先填齐「必要环境变量」。
#
# 开发时：若在仓库根目录使用相对 DATABASE_URL / LOG_FILE，请从仓库根目录启动 CLI，避免
# data/、logs/ 落到错误工作目录。
# =============================================================================

# ----------------------------------------------------------------------------- 
# 推理后端（可选；不设置时程序内保存的 llm_provider 或内置默认生效）
# -----------------------------------------------------------------------------
# 厂商 ID：ollama | deepseek | openai | anthropic | google | groq | custom | …
# LLM_PROVIDER=deepseek

# 工具/function calling 能力（部分小模型需 false）
# LLM_TOOLS_SUPPORTED=true

# ----------------------------------------------------------------------------- 
# Ollama（仅当使用 ollama 且需环境变量兜底时取消注释）
# -----------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3:1b
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_TEMPERATURE=0.7

# ----------------------------------------------------------------------------- 
# DeepSeek（仅当未在程序内保存密钥且需环境变量注入时取消注释）
# -----------------------------------------------------------------------------
# 获取 API Key: https://platform.deepseek.com
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_REASONER_MODEL=deepseek-reasoner
# DEEPSEEK_TEMPERATURE=0.7

# ----------------------------------------------------------------------------- 
# 其他云端厂商（按需；更多见 docs/LLM_PROVIDERS.md）
# -----------------------------------------------------------------------------
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

# LLM_PROVIDER=google
# GOOGLE_API_KEY=

# ----------------------------------------------------------------------------- 
# FastAPI 服务（secbot server；未设置时用代码内置默认）
# -----------------------------------------------------------------------------
# SECBOT_SERVER_HOST=0.0.0.0
# SECBOT_SERVER_PORT=8000
# SECBOT_SERVER_RELOAD=false

# ----------------------------------------------------------------------------- 
# 数据与缓存（持久化库位置；Installed wheel 用户建议固定工作目录或使用绝对路径）
# -----------------------------------------------------------------------------
# DATABASE_URL=sqlite:///./data/secbot.db
# REDIS_URL=

# ----------------------------------------------------------------------------- 
# 日志（未设置时由 Settings 默认；log_level 也可在程序内持久化后覆盖）
# -----------------------------------------------------------------------------
# LOG_LEVEL=INFO
# LOG_FILE=logs/agent.log
# VERBOSE_INIT=false

# LOG_MAX_MESSAGE_CHARS=2000
# LOG_MAX_FIELD_CHARS=1000
# LOG_MAX_LIST_ITEMS=20
# LOG_SENSITIVE_KEYS=password,passwd,token,api_key,authorization,cookie,set-cookie,secret,stdin_data,auth_value
# THOUGHT_CHUNK_LOG_EVERY_N=10
# THOUGHT_CHUNK_MIN_CHARS=80

# ----------------------------------------------------------------------------- 
# 语音（可选）
# -----------------------------------------------------------------------------
# STT_ENGINE=fast_whisper
# STT_MODEL=base
# STT_DEVICE=cpu
# STT_COMPUTE_TYPE=int8
# STT_VAD_FILTER=true
# TTS_ENGINE=gtts

# ----------------------------------------------------------------------------- 
# OSINT / 外部情报（可选；也可通过系统密钥环）
# -----------------------------------------------------------------------------
# SHODAN_API_KEY=
# VIRUSTOTAL_API_KEY=

# ----------------------------------------------------------------------------- 
# 其它
# -----------------------------------------------------------------------------
# PYTHONDONTWRITEBYTECODE=1

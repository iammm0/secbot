# 推理模型后端：ollama（本地 Ollama）| deepseek（DeepSeek 云端 API）
LLM_PROVIDER=ollama

# Ollama 配置（当 LLM_PROVIDER=ollama 时使用）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TEMPERATURE=0.7
# 当前模型是否支持工具/function calling。gemma3:1b 等不支持时设为 false
LLM_TOOLS_SUPPORTED=true

# DeepSeek 配置（当 LLM_PROVIDER=deepseek 时使用，需设置 DEEPSEEK_API_KEY）
# 获取 API Key: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-195c58718d41457e944d66a684794664
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 聊天模式: deepseek-chat | 推理模式（思考链）: deepseek-reasoner（/model deepseek deepseek-reasoner 可切换）
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
DEEPSEEK_TEMPERATURE=0.7

# 语音输入（STT）配置
# 引擎：whisper（openai-whisper）| fast_whisper（faster-whisper，推荐，更快更省显存）
STT_ENGINE=fast_whisper
# 模型：whisper 用 tiny/base/small/medium/large；fast_whisper 还支持 large-v2/large-v3/turbo/distil-large-v3
STT_MODEL=base
# 仅 fast_whisper：设备 cpu 或 cuda
STT_DEVICE=cpu
# 仅 fast_whisper：计算类型。CPU 推荐 int8/float32；GPU 推荐 float16
STT_COMPUTE_TYPE=int8
# 仅 fast_whisper：是否启用 VAD 过滤静音（true/false）
STT_VAD_FILTER=true

# 语音输出（TTS）配置
TTS_ENGINE=gtts

# SQLite数据库配置
DATABASE_URL=sqlite:///./data/secbot.db

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
# 初始化时是否在控制台显示详细日志（默认 false 折叠初始化日志）
VERBOSE_INIT=false